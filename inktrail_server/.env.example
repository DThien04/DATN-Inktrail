NODE_ENV=development
HOST=0.0.0.0
PORT=8080

DATABASE_URL=postgresql://username:password@host:6543/database?pgbouncer=true&connection_limit=10
DIRECT_URL=postgresql://username:password@host:5432/database

JWT_ACCESS_SECRET=replace_with_secure_random_secret
JWT_REFRESH_SECRET=replace_with_secure_random_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
REFRESH_COOKIE_NAME=inktrail_refresh_token

ADMIN_WEB_ORIGIN=http://localhost:3000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
SUPABASE_AVATAR_BUCKET=avatars
SUPABASE_STORY_COVER_BUCKET=story-covers

SMTP_USER=your_email@example.com
SMTP_PASS=replace_with_smtp_app_password
SMTP_FROM=your_email@example.com

GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_COMMENT_MODEL=gemini-2.5-flash
GEMINI_REPORT_MODEL=gemini-2.5-flash-lite
GEMINI_MODERATION_TIMEOUT_MS=3500

ONESIGNAL_APP_ID=replace_with_onesignal_app_id
ONESIGNAL_REST_API_KEY=replace_with_onesignal_rest_api_key
ONESIGNAL_API_URL=https://api.onesignal.com

REDIS_URL=redis://default:password@host:6379
NOTIFICATION_USE_QUEUE=false
WORKER_LOG_COMPLETED=false

